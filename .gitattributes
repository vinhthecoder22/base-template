# Auto detect text files
* text=auto

# Linux scripts
*.sh text eol=lf
mvnw text eol=lf

# Windows scripts
*.cmd text eol=crlf
mvnw.cmd text eol=crlf

# Java & config files → luôn LF
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf

# Optional: markdown / docs
*.md text eol=lf